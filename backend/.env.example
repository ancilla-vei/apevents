PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ap-events?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=7d
NODE_ENV=development

# Admin credentials (stored in DB after first seed)
ADMIN_PHONE=your_admin_phone_here
ADMIN_PASSWORD=your_admin_password_here

# Twilio SMS (for OTP/password reset)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Email (optional, for inquiry replies)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password